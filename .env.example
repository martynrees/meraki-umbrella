# Copy this file to .env and fill in your Umbrella Reporting API credentials
# Generate these under: Umbrella dashboard -> Admin -> API Keys -> Reporting
UMBRELLA_API_KEY=your_key_here
UMBRELLA_API_SECRET=your_secret_here
UMBRELLA_ORG_ID=your_org_id_here

# Meraki Dashboard API credentials, used to look up client info (description,
# MAC, policy, status, device type/OS) when clicking an internal IP.
# Generate an API key under your Meraki profile -> API access -> Generate new API key
# Find your org ID via GET https://api.meraki.com/api/v1/organizations, or in the
# dashboard URL when viewing an organization.
MERAKI_API_KEY=your_meraki_api_key_here
MERAKI_ORG_ID=your_meraki_org_id_here

# Cisco Secure Cloud Analytics (Stealthwatch Cloud) -- optional. Powers the
# Security Alerts section and the open-alert count in the status strip.
# Leave blank if you don't have Secure Cloud Analytics deployed; the app
# degrades gracefully and just shows Meraki alerts instead.
# Generate an API key under your SCA portal -> user menu -> user management.
# SCA_PORTAL_URL is your tenant's portal, e.g. https://your-tenant.obsrvbl.com
SCA_PORTAL_URL=
SCA_API_USER=
SCA_API_KEY=

# How long the combined Meraki health + Secure Cloud Analytics alert data is
# cached before the status strip/Overview/Network Health/Security Alerts
# sections re-fetch from the APIs. Short by design -- this is meant to feel
# close to live, unlike CACHE_TTL_SECONDS below.
NOC_CACHE_TTL_SECONDS=60
